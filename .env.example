# Database
DATABASE_URL=postgresql+asyncpg://careeros:careeros@localhost:5432/careeros

# LLM providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Observability
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=careeros-dev
LANGSMITH_TRACING=true

# App
APP_ENV=local
APP_LOG_LEVEL=INFO

# Budget (EUR)
MONTHLY_BUDGET_EUR=15.00
PER_WORKFLOW_BUDGET_EUR=0.50

# Encryption key for PII at rest (32 bytes base64). Generate with:
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=

# Extension auth
EXTENSION_JWT_SECRET=change-me-in-prod
EXTENSION_JWT_TTL_SECONDS=86400
# Bearer token the Chrome extension sends on POST /api/captures
EXTENSION_API_TOKEN=

# CORS origins (comma-separated). After loading the extension unpacked,
# add chrome-extension://<your-extension-id> here so the popup can POST.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Job-discovery APIs (official partner APIs, NOT scrapers).
# Adzuna: register a free app at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Reed: request a free API key at https://www.reed.co.uk/developers
REED_API_KEY=

# Tavily — web search for the research loop. Free tier at https://tavily.com.
TAVILY_API_KEY=
